+++ b/endcord/terminal_utils.py
@@ -21,6 +21,7 @@
     kernel32.GetConsoleMode(H_STDOUT, ctypes.byref(OLD_OUT_MODE))
 else:
     import fcntl
+    import select
     import termios
     import tty
     STDIN_FD = sys.stdin.fileno()
@@ -124,43 +125,35 @@
